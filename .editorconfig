root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

[*.{js,jsx,ts,tsx,vue,svelte}]
indent_size = 2
max_line_length = 100

[*.{css,scss,less}]
indent_size = 2

[*.{html,vue}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = 120

[*.json]
indent_size = 2

[Makefile]
indent_style = tab
