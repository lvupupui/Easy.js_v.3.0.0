# Server Configuration
PORT=3000
HOST=0.0.0.0

# JWT Configuration
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRY=24h

# Database Configuration
MONGODB_URL=mongodb://localhost:27017/easyjs
MYSQL_URL=mysql://root:password@localhost:3306/easyjs
POSTGRES_URL=postgres://postgres:password@localhost:5432/easyjs
SQLITE_URL=sqlite://./data/easyjs.sqlite
LIBSQL_URL=
LIBSQL_AUTH_TOKEN=
MSSQL_URL=sqlserver://sa:password@localhost:1433/easyjs?trustServerCertificate=true
NEO4J_URL=neo4j://neo4j:password@localhost:7687
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_INDEX=live_users
CASSANDRA_CONTACT_POINTS=127.0.0.1
CASSANDRA_KEYSPACE=easyjs
CASSANDRA_LOCAL_DATACENTER=datacenter1
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_TABLE=live_users
FIREBASE_PROJECT_ID=
FIREBASE_DATABASE_URL=
FIREBASE_CREDENTIALS_JSON=
FIREBASE_CREDENTIALS_BASE64=
FIREBASE_CREDENTIALS_FILE=
DYNAMODB_ENDPOINT=
DYNAMODB_TABLE=live_users

# Redis Configuration (Optional)
REDIS_URL=redis://localhost:6379

# Environment
NODE_ENV=development
DEBUG=false

# CORS Configuration
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Observability
LOG_LEVEL=info
SENTRY_DSN=
PROMETHEUS_ENABLED=true

# AI Providers
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Security / Compliance
FIELD_ENCRYPTION_KEY=replace-with-32-byte-secret
API_KEY_SALT=replace-with-api-key-salt

# Cloud Storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
GCP_PROJECT_ID=
GCP_KEY_FILE=
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email Providers
SENDGRID_API_KEY=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
