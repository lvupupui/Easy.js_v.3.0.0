START SERVER 3000
USE MONGODB mongodb://localhost:27017/easy_auth

MODEL users {
  name: string
  email: email
  password: password
  role: string
  createdAt: date
}

AUTH users BY jwt

GET /users FROM users
GET /users/:id FROM users
POST /users FROM users
PUT /users/:id FROM users
DELETE /users/:id FROM users
PROTECT /users

VALIDATE users {
  name: required:min=2
  email: required:email
  password: required:min=8
}
