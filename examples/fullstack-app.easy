// Complete Full-Stack Application Example
// This generates backend API, frontend UI, ML models, and deployment configuration

// ===== SERVER CONFIGURATION =====
START SERVER 3000
USE MONGODB mongodb://localhost:27017/easyapp

// ===== FRONTEND CONFIGURATION =====
USE FRONTEND react                    // Options: react, vue, svelte
USE CSS_FRAMEWORK tailwind            // Options: tailwind, bootstrap, material
USE COMPONENTS_LIBRARY true           // Auto-generate UI components

// ===== ML CONFIGURATION =====
USE ML tensorflow.js
ML_MODEL fraud_detector {
  input_shape: 10
  output_shape: 2
  train_epochs: 50
  batch_size: 32
}

ML_MODEL recommendation_engine {
  input_shape: 20
  output_shape: 5
  train_epochs: 100
  batch_size: 64
}

// ===== DATABASE MODELS =====

MODEL users {
  email: string
  password: string
  firstName: string
  lastName: string
  avatar: string
  role: enum(user, admin, moderator)
  isActive: boolean
  createdAt: date
}

MODEL products {
  name: string
  description: string
  price: number
  category: string
  stock: number
  image: string
  rating: number
  reviews: array
  createdBy: reference(users)
}

MODEL orders {
  orderNumber: string
  user: reference(users)
  products: array(reference(products))
  total: number
  status: enum(pending, processing, shipped, delivered, cancelled)
  shippingAddress: string
  paymentMethod: string
  createdAt: date
  updatedAt: date
}

MODEL reviews {
  product: reference(products)
  user: reference(users)
  rating: number
  comment: string
  helpful: number
  createdAt: date
}

MODEL transactions {
  order: reference(orders)
  amount: number
  status: enum(pending, completed, failed, refunded)
  transactionId: string
  paymentGateway: string
  createdAt: date
}

// ===== AUTHENTICATION =====
AUTH users BY jwt
MFA users REQUIRED
OAUTH users BY google, github, microsoft

// ===== PASSWORD POLICY =====
PASSWORD_POLICY {
  min_length: 8
  require_uppercase: true
  require_numbers: true
  require_special: true
}

// ===== API ENDPOINTS =====

// User Management
POST /auth/register FROM users VALIDATE auth.register
POST /auth/login FROM users VALIDATE auth.login
POST /auth/refresh FROM users
POST /auth/logout FROM users
GET /auth/me FROM users PROTECT

// User Endpoints
GET /users FROM users PROTECT ADMIN
GET /users/:id FROM users PROTECT
PUT /users/:id FROM users PROTECT
DELETE /users/:id FROM users PROTECT ADMIN

// Product Management
GET /products FROM products CACHE 1h
GET /products/:id FROM products CACHE 1h
POST /products FROM products PROTECT
PUT /products/:id FROM products PROTECT
DELETE /products/:id FROM products PROTECT ADMIN
SEARCH /products/search FROM products QUERY name,category

// Orders
POST /orders FROM orders PROTECT
GET /orders FROM orders PROTECT
GET /orders/:id FROM orders PROTECT
PUT /orders/:id/status FROM orders PROTECT
GET /my-orders FROM orders PROTECT
CANCEL_ORDER /orders/:id FROM orders PROTECT

// Reviews
POST /products/:productId/reviews FROM reviews PROTECT
GET /products/:productId/reviews FROM reviews
PUT /reviews/:id FROM reviews PROTECT
DELETE /reviews/:id FROM reviews PROTECT

// ML Predictions
POST /ml/fraud_detector/predict PREDICT fraud_detector
POST /ml/fraud_detector/batch BATCH_PREDICT fraud_detector
GET /ml/fraud_detector/stats STATS fraud_detector

POST /ml/recommendation/predict PREDICT recommendation_engine
POST /ml/recommendation/batch BATCH_PREDICT recommendation_engine
GET /ml/recommendation/stats STATS recommendation_engine

// ===== VALIDATION RULES =====

VALIDATE auth.register {
  email: required:email
  password: required:min=8:max=128:regex=^(?=.*[A-Z])(?=.*[0-9])(?=.*[!@#$%^&*])
  firstName: required:min=2:max=50
  lastName: required:min=2:max=50
}

VALIDATE auth.login {
  email: required:email
  password: required
}

VALIDATE products {
  name: required:min=3:max=200
  description: required:min=10:max=5000
  price: required:numeric:min=0
  category: required
  stock: required:numeric:min=0
}

VALIDATE orders {
  products: required:array:min=1
  total: required:numeric:min=0
  shippingAddress: required
  paymentMethod: required
}

VALIDATE reviews {
  rating: required:numeric:min=1:max=5
  comment: required:min=10:max=1000
}

// ===== MIDDLEWARE & SECURITY =====

RATE_LIMIT /auth/login 5 per 15m
RATE_LIMIT /auth/register 3 per 24h
RATE_LIMIT /api/* 100 per 1m

ENCRYPTION {
  sensitive_fields: password, cardNumber, ssn
  algorithm: AES-256
}

AUDIT_LOG {
  track: all
  retention: 90d
}

CORS {
  origins: http://localhost:5173, https://example.com
  methods: GET, POST, PUT, DELETE, PATCH
  credentials: true
}

CSP {
  default_src: self
  script_src: self, cdn.jsdelivr.net
  style_src: self, fonts.googleapis.com
}

// ===== REAL-TIME FEATURES =====

WEBSOCKET {
  namespace: /notifications
  events: order_update, product_new, review_posted
}

SUBSCRIBE /orders/:id  // Real-time order updates
SUBSCRIBE /products/:id // Real-time product changes

// ===== CACHING STRATEGY =====

CACHE products 1h
CACHE /products/trending 30m
CACHE /users/:id 5m
INVALIDATE /products/* ON product.update
INVALIDATE /products/:id ON product.delete

// ===== DATABASE INDEXES =====

INDEX users.email UNIQUE
INDEX products.category
INDEX orders.status
INDEX orders.userId
INDEX reviews.productId

// ===== ANALYTICS =====

TRACK {
  events: page_view, product_viewed, purchase, review_posted
  retention: 1y
}

DASHBOARD {
  title: "Analytics Dashboard"
  metrics: [
    daily_users,
    total_revenue,
    conversion_rate,
    average_order_value
  ]
}

// ===== DEPLOYMENT =====

DEPLOY {
  platform: vercel, aws, docker
  auto_scaling: true
  health_check: true
  cdn: cloudflare
}

DOCKER {
  base_image: node:18-alpine
  include: backend, frontend, ml
}

CI_CD {
  provider: github
  on_push: test, build, deploy
}

// ===== GENERATED OUTPUTS =====

GENERATE {
  api_docs: openapi.json, swagger.json
  typescript_types: true
  client_sdk: javascript, python, ruby
  react_hooks: true
  vue_composables: true
}

// ===== ENV VARIABLES =====

ENV_VARS {
  DATABASE_URL: mongodb://localhost:27017/easyapp
  JWT_SECRET: your-secret-key
  OAUTH_GOOGLE_ID: google-client-id
  OAUTH_GOOGLE_SECRET: google-client-secret
  STRIPE_KEY: stripe-api-key
}

// ===== COMPLETE FEATURES SUMMARY =====

